{
    "version": "2.0",
    "logging": {
	  "applicationInsights": {
		"samplingSettings": {
		  "isEnabled": true,
		  "excludedTypes": "Request"
		},
		"enableLiveMetricsFilters": true
	  },
	  "fileLoggingMode": "always",
	  "logLevel": {
		"default": "Error",
		"Host.Results": "Error",
		"Function": "Error",
		"Host.Aggregator": "Error"
	  }
    }
}